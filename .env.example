# Copy relevant lines to ~/.aegis/.env (or run `aegis config set <KEY> <value>`).
# Only the key for the provider you use is required.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=
TOGETHER_API_KEY=

# Local / OpenAI-compatible endpoints need no key:
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Google OAuth (only if you use `aegis auth login google`):
# the Gemini-CLI public installed-app client secret (GOCSPX-...). Not shipped in source.
# GOOGLE_OAUTH_CLIENT_SECRET=

# Gateway channels
TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=123456789,987654321
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
DISCORD_BOT_TOKEN=
