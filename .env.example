# Copy relevant lines to ~/.aegis/.env (or run `aegis config set <KEY> <value>`).
# Only the key for the provider you use is required.

ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
GROQ_API_KEY=
DEEPSEEK_API_KEY=
XAI_API_KEY=
MISTRAL_API_KEY=
TOGETHER_API_KEY=
HF_TOKEN=
NOVITA_API_KEY=
ZAI_API_KEY=
KIMI_API_KEY=
MINIMAX_API_KEY=
NVIDIA_API_KEY=
DASHSCOPE_API_KEY=
STEPFUN_API_KEY=
CEREBRAS_API_KEY=
PERPLEXITY_API_KEY=
FIREWORKS_API_KEY=
HYPERBOLIC_API_KEY=
SAMBANOVA_API_KEY=
NOUS_API_KEY=
# A comma-separated list rotates as a credential pool on rate-limits:
# OPENAI_API_KEY=sk-key1,sk-key2,sk-key3

# Local / OpenAI-compatible endpoints need no key:
# OLLAMA_BASE_URL=http://localhost:11434/v1

# Google OAuth (only if you use `aegis auth login google`):
# the Gemini-CLI public installed-app client secret (GOCSPX-...). Not shipped in source.
# GOOGLE_OAUTH_CLIENT_SECRET=

# Gateway channels
TELEGRAM_BOT_TOKEN=
# TELEGRAM_ALLOWED_USERS=123456789,987654321
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
DISCORD_BOT_TOKEN=
# Signal (needs the signal-cli binary): the registered phone number
SIGNAL_CLI_ACCOUNT=
# Matrix (needs `pip install matrix-nio`)
MATRIX_HOMESERVER=
MATRIX_USER=
MATRIX_PASSWORD=
# Gateway access control
# GATEWAY_ALLOW_ALL_USERS=0
# TELEGRAM_ALLOW_ALL_USERS=0
