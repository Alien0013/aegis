{
  "name": "aegis-tui",
  "version": "0.1.0",
  "private": true,
  "description": "AEGIS terminal UI — a Node/Ink front-end that talks to the Python agent over a local WebSocket gateway.",
  "license": "MIT",
  "type": "module",
  "bin": {
    "aegis-tui": "dist/entry.js"
  },
  "scripts": {
    "build": "esbuild src/entry.tsx --bundle --platform=node --format=esm --target=node18 --outfile=dist/entry.js --legal-comments=external --alias:react-devtools-core=./src/devtools-stub.js --banner:js=\"import{createRequire}from'module';const require=createRequire(import.meta.url);\"",
    "typecheck": "tsc --noEmit",
    "dev": "node dist/entry.js"
  },
  "dependencies": {
    "ink": "^5.0.1",
    "ink-text-input": "^6.0.0",
    "react": "^18.3.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.3",
    "@types/ws": "^8.5.10",
    "esbuild": "^0.23.0",
    "typescript": "^5.5.0"
  }
}
